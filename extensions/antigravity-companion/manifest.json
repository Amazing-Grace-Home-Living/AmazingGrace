{
  "manifest_version": 3,
  "name": "Antigravity Nexus Companion",
  "version": "1.0.0",
  "description": "Mobile companion dashboard for Antigravity AI chat and Gemini CLI.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  }
}
